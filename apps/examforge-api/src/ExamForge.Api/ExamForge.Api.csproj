    <UserSecretsId>48df92e8-fab7-4d9c-ae30-7b0c02200ceb</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
